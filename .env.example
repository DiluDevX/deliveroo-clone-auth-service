PORT=3000
NODE_ENV=development
SERVICE_NAME=auth-service

# In production, these come from AWS Secrets Manager
# For local development, uncomment and set these:
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb?schema=public
# JWT_SECRET=example-secret
# DELIVEROO_CLONE_API_KEY=example-key

# Email (required in production, optional in development — falls back to test-key-development-only)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# JWT Configuration
JWT_EXPIRES_IN=15
JWT_REFRESH_EXPIRES_IN=7
JWT_RESET_PASSWORD_EXPIRES_IN=1

LOG_LEVEL=info

APP_VERSION=1.0.0
BASE_URL=http://localhost:3000

COMPANY_NAME="Local Development"
COMPANY_EMAIL=noreply@localhost
LOGO_URL=https://via.placeholder.com/200?text=Logo
SUPPORT_EMAIL=support@localhost
APP_URL=http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
